# Database
DATABASE_URL=postgresql://postgres:CHANGEME@localhost:5432/smarthub
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_MAX_CONNECTIONS=50
DASHBOARD_CACHE_TTL_SECONDS=300

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_DELAYED_EXCHANGE=cixio.delayed
RABBITMQ_TOPIC_EXCHANGE=cixio.topic

# Security
SECRET_KEY=change-this-in-production-to-a-secure-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120
OLLAMA_CONNECT_TIMEOUT=10

# Storage
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=26214400

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# App
ENVIRONMENT=development